# =============================================
# VOLTS APPLICATION - ENVIRONMENT VARIABLES
# =============================================
# Copy this file to .env and fill in your keys.
# DO NOT commit .env to GitHub!
# =============================================

# --- AI ENGINES (Required for Core Features) ---
GEMINI_API_KEY=
REPLICATE_API_TOKEN=
HF_TOKEN=

# --- VOICE & TELEPHONY (Required for AI Dialer) ---
VAPI_API_KEY=
VAPI_PHONE_ID=
ELEVENLABS_API_KEY=

# --- TWILIO (Optional Legacy Telephony) ---
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- PAYMENTS (Required for Billing) ---
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=

# --- SOCIAL MEDIA SCRAPERS (Optional) ---
FB_EMAIL=
FB_PASS=
INSTA_USER=
INSTA_PASS=
TG_API_ID=
TG_API_HASH=
X_USER=
X_PASS=

# --- EMAIL OUTREACH (Optional) ---
GMAIL_USER=
GMAIL_APP_PASS=
NOTIFY_EMAIL=

# --- APPLICATION (Set for Production) ---
APP_BASE_URL=http://localhost:8501
